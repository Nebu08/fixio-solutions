# Variables de entorno para el backend de Fixio Solutions (Render.com)
# Copia este archivo como .env para desarrollo local

# ── MERCADO PAGO ─────────────────────────────────────────────────
# Obtén tu Access Token en: https://www.mercadopago.com.co/settings/account/credentials
MP_ACCESS_TOKEN=APP_USR-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── SERVIDOR ─────────────────────────────────────────────────────
PORT=3001

# ── CORS — URL de tu frontend en producción ──────────────────────
# Ej: https://fixiosolutions.com  ó  https://tu-sitio.hostinger.app
SITE_URL=https://tu-sitio.com
FRONTEND_URL=https://tu-sitio.com

# ── ADMIN (credenciales de acceso al dashboard) ──────────────────
ADMIN_EMAIL=admin@fixiosolutions.com
ADMIN_PASSWORD=cambia_esta_password
